<!-- 
  Le container principal de la page
  Toutes les variables {{ }} viennent de data dans index.js 
-->
<view class="page-container">

  <!-- ===== HEADER ===== -->
  <view class="header">
    <text class="header-title">🛍️ Boutique</text>

    <!-- 
      Le panier — affiche le nombre d'articles
      {{ panierCount }} sera mis à jour par setData()
    -->
    <view class="panier-badge">
      <text class="panier-icon">🛒</text>
      <text class="panier-count">{{ panierCount }}</text>
    </view>
  </view>

  <!-- ===== ETAT CHARGEMENT ===== -->
  <!-- 
    wx:if → affiche cet élément SEULEMENT si isLoading est true
    Pendant que l'API charge, on montre ce message
  -->
  <view wx:if="{{ isLoading }}" class="loading-container">
    <text class="loading-text">Chargement des produits...</text>
  </view>

  <!-- ===== ETAT ERREUR ===== -->
  <!-- 
    wx:elif → si pas en chargement ET hasError est true
  -->
  <view wx:elif="{{ hasError }}" class="error-container">
    <text class="error-text">❌ Erreur de chargement</text>
    <app-button 
      label="Réessayer" 
      bind:tap="chargerProduits"
    />
  </view>

  <!-- ===== LISTE PRODUITS ===== -->
  <!-- 
    wx:else → si pas en chargement ET pas d'erreur
    wx:for → boucle sur le tableau produits
    wx:key → identifiant unique pour chaque élément (performance)
  -->
  <view wx:else class="produits-container">

    <!-- 
      wx:for="{{ produits }}" → répète ce bloc pour chaque produit
      item → l'objet produit courant (automatique)
      index → l'index courant 0, 1, 2... (automatique)
    -->
    <app-card 
      wx:for="{{ produits }}" 
      wx:key="id"
      class="produit-card"
    >
      <!-- Image du produit -->
      <image 
        class="produit-image" 
        src="{{ item.image }}" 
        mode="aspectFill"
      />

      <!-- Infos produit -->
      <view class="produit-info">
        <text class="produit-nom">{{ item.nom }}</text>
        <text class="produit-prix">{{ item.prix }} FCFA</text>
        <text class="produit-description">{{ item.description }}</text>
      </view>

      <!-- 
        Bouton ajouter au panier
        data-id="{{ item.id }}" → passe l'id du produit au gestionnaire
        bind:tap → quand l'utilisateur appuie
      -->
      <app-button
      class="app-button"
        label="Ajouter au panier"
        data-id="{{ item.id }}"
        data-nom="{{ item.nom }}"
        data-prix="{{ item.prix }}"
        bind:tap="ajouterAuPanier"
      >Ajouter au panier</app-button>
      
    </app-card>

    <!-- Message si aucun produit -->
    <view wx:if="{{ produits.length === 0 }}" class="empty-container">
      <text class="empty-text">Aucun produit disponible</text>
    </view>

  </view>

</view>