/* ===== CONTAINER PRINCIPAL ===== */
.page-container {
  /* 
    min-height: 100vh → prend toute la hauteur de l'écran
    background-color → fond gris clair
  */
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
  margin-top: 5%;
}

/* ===== HEADER ===== */
.header {
  /* 
    display: flex → les enfants s'alignent en ligne
    justify-content: space-between → titre à gauche, panier à droite
    align-items: center → centré verticalement
  */
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background-color: #ffffff;
  border-radius: 16rpx;

  position: fixed;   /* fixe par rapport à l'écran */
  top: 5%;
           /* collé en haut */
  left: 0;           /* depuis le bord gauche */
  right: 0;          /* jusqu'au bord droit */
  z-index: 999; 
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
}

/* ===== BADGE PANIER ===== */
.panier-badge {
  display: flex;
  align-items: center;
  background-color: #085EBD;
  padding: 8rpx 16rpx;
  border-radius: 32rpx;
}

.panier-icon {
  font-size: 32rpx;
}

.panier-count {
  /* 
    rpx → unité responsive
    750rpx = largeur totale de l'écran sur tout appareil
  */
  font-size: 28rpx;
  color: #ffffff;
  margin-left: 8rpx;
  font-weight: bold;
}

/* ===== ETATS ===== */
.loading-container,
.error-container,
.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}

.loading-text,
.error-text,
.empty-text {
  font-size: 32rpx;
  color: #999999;
  margin-bottom: 24rpx;
}

/* ===== LISTE PRODUITS ===== */
.produits-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.produit-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

/* ===== IMAGE PRODUIT ===== */
.produit-image {
  /* 
    width: 100% → prend toute la largeur de la card
    height: 300rpx → hauteur fixe
    border-radius → coins arrondis
  */
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

/* ===== INFOS PRODUIT ===== */
.produit-info {
  margin-bottom: 16rpx;
}

.produit-nom {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  margin-left: 5%;
}

.produit-prix {
  font-size: 32rpx;
  color: #085EBD;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
  margin-left: 5%;
  
}

.produit-description {
  font-size: 28rpx;
  color: #666666;
  display: block;
  margin-left: 5%;

}
.app-button{
  color: white;
}